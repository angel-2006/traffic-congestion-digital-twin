<configuration>
    <input>
        <net-file value="../maps/silk_board_corridor.net.xml"/>
        <route-files value="../routes/routes.rou.xml"/>
    </input>

    <time>
        <begin value="0"/>
        <end value="3600"/>
    </time>

    <output>
        <summary-output value="../outputs/summary.xml"/>
        <tripinfo-output value="../outputs/tripinfo.xml"/>
    </output>
</configuration>